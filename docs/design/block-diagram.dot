digraph BlockDiagram {
    rankdir=TB;
    node [shape=box, style=filled, fillcolor=lightgrey, fontname="Helvetica"];

    // ── Power ──────────────────────────────────────────────────────────────
    Power [label="Power", fillcolor=lightyellow];

    // ── Controllers cluster ────────────────────────────────────────────────
    subgraph cluster_controllers {
        label="Controllers";
        style=filled;
        fillcolor=aliceblue;
        color=steelblue;

        MCU          [label="MCU\n(Microcontroller)", fillcolor=lightblue];
        MotorControl [label="Motor Control", fillcolor=lightgreen];
        LaserControl [label="Laser Control", fillcolor=lightsalmon];
    }

    // ── Actuators cluster ──────────────────────────────────────────────────
    subgraph cluster_actuators {
        label="Actuators";
        style=filled;
        fillcolor=honeydew;
        color=darkgreen;

        StepperX    [label="Stepper Motor X", fillcolor=white];
        StepperY    [label="Stepper Motor Y", fillcolor=white];
        LaserModule [label="Laser Module", fillcolor=white];
    }

    // ── Power outputs ──────────────────────────────────────────────────────
    Power -> MCU          [label="3.3V"];
    Power -> LaserControl [label="5V"];
    Power -> MotorControl [label="12V"];

    // ── MCU outputs ────────────────────────────────────────────────────────
    MCU -> MotorControl [label="SPI_1"];
    MCU -> MotorControl [label="SPI_2"];
    MCU -> LaserControl [label="GPIO"];

    // ── Actuator connections ───────────────────────────────────────────────
    MotorControl -> StepperX    [label="Stepper Drive X"];
    MotorControl -> StepperY    [label="Stepper Drive Y"];
    LaserControl -> LaserModule [label="Laser Drive"];
}